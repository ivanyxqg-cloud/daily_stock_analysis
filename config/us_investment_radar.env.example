# US investment radar defaults for GitHub Actions.
# Copy values from this file into GitHub repository Variables unless noted as Secrets.

# Public/non-sensitive Variables
OPENAI_MODEL=gpt-5.4-mini
REPORT_LANGUAGE=zh
MARKET_REVIEW_REGION=us
MARKET_REVIEW_ENABLED=true
REPORT_TYPE=full
REPORT_PROFILE=us_investment_radar
REPORT_SUMMARY_ONLY=false
SINGLE_STOCK_NOTIFY=false
PORTFOLIO_STOCK_LIST=AVGO,BABA,CRWV,OKLO,PLTR,QQQ,SNDK,TSM,VRT
OPPORTUNITY_MAX=8
RISK_WATCH_MAX=8
MAX_WORKERS=1
ANALYSIS_DELAY=5
STOCK_LIST=NVDA,MSFT,AAPL,AMZN,GOOGL,META,TSLA,AMD,AVGO,TSM,PLTR,JPM,V,LLY,COST,SPY,QQQ,SMH,TLT,GLD,BABA,CRWV,OKLO,SNDK,VRT,SPX,NASDAQ,VIX,IWM,XLK,XLF,XLE,HYG,UUP

# Sensitive values must be GitHub Actions Secrets, not committed files:
# OPENAI_API_KEY
# TELEGRAM_BOT_TOKEN
# TELEGRAM_CHAT_ID
# TAVILY_API_KEYS or BRAVE_API_KEYS
